{
  "name": "twzipcode-vue",
  "description": "中華郵政郵遞區號 Vue components",
  "version": "3.0.0",
  "author": "Yeh-Yung <yyc1217@gmail.com>",
  "type": "module",
  "main": "dist/twzipcode.umd.js",
  "module": "dist/twzipcode.es.js",
  "unpkg": "dist/twzipcode.umd.js",
  "exports": {
    ".": {
      "import": "./dist/twzipcode.es.js",
      "require": "./dist/twzipcode.umd.js"
    }
  },
  "browser": {
    "./zipcode": "src/components/zipcodes.vue",
    "./zipcode-groupby": "src/components/zipcodes.groupby.vue",
    "./county": "src/components/counties.vue"
  },
  "files": [
    "dist",
    "src/index.js",
    "src/components"
  ],
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --config vite.demo.config.js",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "publint": "publint --pack npm",
    "prepublishOnly": "yarn lint && yarn test && yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yyc1217/twzipcode-vue.git"
  },
  "keywords": [
    "Taiwan",
    "zipcode",
    "中華郵政",
    "臺灣",
    "郵遞區號"
  ],
  "homepage": "https://github.com/yyc1217/twzipcode-vue#readme",
  "bugs": {
    "url": "https://github.com/yyc1217/twzipcode-vue/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "twzipcode-data": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9",
    "eslint-plugin-vue": "^9",
    "jsdom": "^26.0.0",
    "publint": "^0.3",
    "sass": "^1.83.4",
    "should": "^13.2.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5",
    "vue": "^3.5.13"
  }
}
